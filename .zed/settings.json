{
  "languages": {
    "Nix": {
      "formatter": {
        "external": {
          "command": "nix",
          "arguments": [
            "fmt",
            "--",
            "--stdin",
            "{buffer_path}",
            "-q"
          ]
        }
      },
      "format_on_save": "on"
    }
  }
}
